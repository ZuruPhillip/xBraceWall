## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.user
*.suo

# Visual Studio folder (anywhere in repo)
.vs/
**/bin/
**/obj/

# CNC Station
CncWallStation/bin/
CncWallStation/obj/


# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Rr]ef/

# Hidden folders
.hidden/