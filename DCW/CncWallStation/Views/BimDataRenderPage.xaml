<Page x:Class="CncWallStation.Views.BimDataRenderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:CncWallStation.ViewModels" 
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="BIM 3D 墙体渲染">

    <Page.Resources>
        <!-- 按钮统一样式 -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 次级按钮样式 -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button"
               BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background" Value="#475569"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#94A3B8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <!-- 标题栏 -->
            <RowDefinition Height="56"/>
            <!-- 工具栏 -->
            <RowDefinition Height="52"/>
            <!-- WebView2 渲染区域（主体） -->
            <RowDefinition Height="*"/>
            <!-- 状态栏 -->
            <RowDefinition Height="36"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!--  Row 0 · 标题栏                            -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#1E3A5F"
                BorderBrush="#2563EB"
                BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 图标 + 标题 -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0">
                    <TextBlock Text="🧱"
                               FontSize="24"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="BIM 数据渲染"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="AAC 墙体三维可视化 · Three.js"
                                   FontSize="11"
                                   Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <!-- 墙体参数信息 -->
                <TextBlock Grid.Column="1"
                           Text="{Binding WallInfo}"
                           Foreground="#60A5FA"
                           FontSize="13"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>


            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ -->
        <!--  Row 1 · 工具栏                            -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#1E293B"
                BorderBrush="#334155"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0">

                <!-- 🔵 主操作 -->
                <Button Content="🚀 加载渲染"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding LoadRenderCommand}"
                        ToolTip="加载 Three.js AAC 墙体 3D 渲染页面"/>

                <Separator Width="1" Height="24"
                           Background="#334155" Margin="6,0"/>

                <!-- 视角控制 -->
                <Button Content="🔄 重置视角"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ResetViewCommand}"
                        ToolTip="重置摄像机到默认视角（等同页面双击）"/>

                <Button Content="🧱 砖块图层"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ToggleBrickLayerCommand}"
                        ToolTip="切换砖块图层的显示/隐藏"/>

                <Button Content="📐 标注图层"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ToggleAnnotationCommand}"
                        ToolTip="切换尺寸标注图层的显示/隐藏"/>

                <Separator Width="1" Height="24"
                           Background="#334155" Margin="6,0"/>

                <Button Content="📤 导出"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ExportCommand}"
                        ToolTip="导出当前渲染截图"/>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════ -->
        <!--  Row 2 · WebView2 渲染主区域               -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- WebView2 控件：嵌入 Three.js HTML 页面 -->
            <wv2:WebView2 x:Name="BimWebView"
                          NavigationCompleted="BimWebView_NavigationCompleted"
                          NavigationStarting="BimWebView_NavigationStarting"
                          CoreWebView2InitializationCompleted="BimWebView_CoreWebView2InitializationCompleted"/>

            <!-- 占位遮罩：未加载时显示 -->
            <Border x:Name="PlaceholderPanel"
                    Background="#0F172A"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="20">

                    <TextBlock Text="🧱"
                               FontSize="64"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="AAC 墙体三维渲染"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="基于 Three.js 的 BIM 数据可视化"
                               FontSize="15"
                               Foreground="#64748B"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>

                    <TextBlock HorizontalAlignment="Center"
                               Margin="0,24,0,0">
                        <Run Text="■ X 轴（宽度）" Foreground="#60A5FA"/>
                        <Run Text="1400 mm" Foreground="White" FontWeight="SemiBold"/>
                        <Run Text="  ■ Y 轴（高度）" Foreground="#34D399"/>
                        <Run Text="2695 mm" Foreground="White" FontWeight="SemiBold"/>
                        <Run Text="  ■ Z 轴（厚度）" Foreground="#FBBF24"/>
                        <Run Text="298 mm" Foreground="White" FontWeight="SemiBold"/>
                    </TextBlock>

                    <TextBlock Text="点击上方 🚀 加载渲染 按钮以启动 Three.js 3D 场景"
                               FontSize="14"
                               Foreground="#475569"
                               HorizontalAlignment="Center"
                               Margin="0,32,0,0"/>

                    <!-- 操作提示卡片 -->
                    <Border Background="#1E293B"
                            CornerRadius="8"
                            Padding="20,14"
                            Margin="0,20,0,0"
                            MaxWidth="500">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="🖱 交互操作" Foreground="#94A3B8"
                                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="左键 · 旋转场景" Foreground="#CBD5E1" FontSize="12"/>
                                <TextBlock Text="右键 · 平移视图" Foreground="#CBD5E1" FontSize="12"/>
                                <TextBlock Text="滚轮 · 缩放" Foreground="#CBD5E1" FontSize="12"/>
                                <TextBlock Text="双击 · 复位视角" Foreground="#CBD5E1" FontSize="12"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="🔍 悬停检测" Foreground="#94A3B8"
                                           FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBlock Text="悬停墙边 · 测量长度" Foreground="#CBD5E1" FontSize="12"/>
                                <TextBlock Text="悬停砖块 · 显示信息" Foreground="#CBD5E1" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!--  Row 3 · 状态栏                            -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="#0F172A"
                BorderBrush="#1E293B"
                BorderThickness="0,1,0,0">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="#94A3B8"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           Text="ShutteringStation · BIM 渲染模块 v1.0"
                           Foreground="#334155"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
